# Sao chép file này thành .env và điền thông tin ứng dụng PayPal Sandbox.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_VND_PER_USD=25000
QR_BANK_ID=
QR_ACCOUNT_NO=
QR_ACCOUNT_NAME=KHAM PHA VIET

# Gmail SMTP (dùng App Password, không dùng mật khẩu Gmail chính)
EMAIL_NOTIFICATIONS_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Đồ án mặc định ghi SMS vào nhật ký thay vì gửi và tính phí thật
SMS_SANDBOX=true

# Chính sách timeout vận hành (phút)
RESERVATION_HOLD_MINUTES=10
CLEANING_BUFFER_MINUTES=15
UPCOMING_ALERT_MINUTES=30
LATE_WARNING_MINUTES=15
LATE_CRITICAL_MINUTES=20
TABLE_REQUEST_ACK_MINUTES=3
KITCHEN_CRITICAL_OVERDUE_MINUTES=10
CLEANING_TARGET_MINUTES=15
TIMEOUT_MONITOR_DELAY_MS=60000
