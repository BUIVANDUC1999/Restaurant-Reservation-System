# Sao chép file này thành .env và điền thông tin ứng dụng PayPal Sandbox.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_VND_PER_USD=25000
QR_BANK_ID=
QR_ACCOUNT_NO=
QR_ACCOUNT_NAME=KHAM PHA VIET

# Gmail SMTP (dùng App Password, không dùng mật khẩu Gmail chính)
EMAIL_NOTIFICATIONS_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Đồ án mặc định ghi SMS vào nhật ký thay vì gửi và tính phí thật
SMS_SANDBOX=true
